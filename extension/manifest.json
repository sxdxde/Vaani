{
  "manifest_version": 3,
  "name": "Vaani — वाणी",
  "version": "1.0.0",
  "description": "Your professional voice in English. Convert Hinglish or code-switched text into polished professional English.",
  "permissions": [],
  "host_permissions": [
    "https://api.groq.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vaani — वाणी",
